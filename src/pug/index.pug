doctype html
html(lang='en')

    head

        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='Exporra is an AI-powered trade compliance platform for automated export classification (ECCN and HS code), sanction screening, denied/restricted party (KYC) checks, and continuous monitoring of OFAC, BIS, EU, and UN sanctions lists.')
        meta(name='keywords', content='export classification, ECCN classification, HS code classification, sanction screening, denied party screening, restricted party screening, KYC screening, OFAC screening, BIS, EU sanctions list, dual-use goods, trade compliance software')
        meta(name='author', content='Exporra')
        meta(name='robots', content='index, follow, max-image-preview:large')
        meta(name='theme-color', content='#1abc9c')

        title Exporra — AI Export Classification (ECCN/HS Code) & Sanction Screening

        // Canonical URL
        link(rel='canonical', href='https://www.exporra.com/')

        // Open Graph / Facebook
        meta(property='og:type', content='website')
        meta(property='og:site_name', content='Exporra')
        meta(property='og:url', content='https://www.exporra.com/')
        meta(property='og:title', content='Exporra — AI Export Classification (ECCN/HS Code) & Sanction Screening')
        meta(property='og:description', content='AI-powered ECCN and HS code classification, sanction screening, and KYC/denied party checks. Simplify trade compliance with continuous monitoring of OFAC, BIS, EU and UN lists.')
        meta(property='og:image', content='https://www.exporra.com/assets/img/logo.webp')
        meta(property='og:locale', content='en_US')

        // Twitter
        meta(name='twitter:card', content='summary_large_image')
        meta(name='twitter:title', content='Exporra — AI Export Classification & Sanction Screening')
        meta(name='twitter:description', content='AI-powered ECCN/HS code classification and sanction screening. Continuous monitoring of OFAC, BIS, EU and UN sanctions lists.')
        meta(name='twitter:image', content='https://www.exporra.com/assets/img/logo.webp')

        // Favicon
        link(rel='icon', type='image/x-icon', href='assets/favicon.ico')
        link(rel='shortcut icon', type='image/x-icon', href='assets/favicon.ico')
        link(rel='apple-touch-icon', href='assets/img/logo.webp')

        // Performance: preconnect to font hosts
        link(rel='preconnect', href='https://fonts.googleapis.com')
        link(rel='preconnect', href='https://fonts.gstatic.com', crossorigin='')
        link(rel='preconnect', href='https://use.fontawesome.com')

        // Font Awesome icons (CSS version — non render-blocking on first paint)
        link(rel='stylesheet', href='https://use.fontawesome.com/releases/v6.3.0/css/all.css', crossorigin='anonymous')

        // Google fonts (combined request)
        link(href='https://fonts.googleapis.com/css?family=Montserrat:400,700|Lato:400,700,400italic,700italic&display=swap', rel='stylesheet', type='text/css')

        // Core theme CSS (includes Bootstrap)
        link(href='css/styles.css', rel='stylesheet')

        // Structured data — Organization
        script(type='application/ld+json').
            {
                "@context": "https://schema.org",
                "@type": "Organization",
                "name": "Exporra",
                "url": "https://www.exporra.com/",
                "logo": "https://www.exporra.com/assets/img/logo.webp",
                "description": "AI-powered trade compliance platform for export classification (ECCN, HS code) and sanction/denied party screening.",
                "email": "Info@exporra.com"
            }

        // Structured data — SoftwareApplication
        script(type='application/ld+json').
            {
                "@context": "https://schema.org",
                "@type": "SoftwareApplication",
                "name": "Exporra",
                "applicationCategory": "BusinessApplication",
                "operatingSystem": "Web",
                "url": "https://www.exporra.com/",
                "description": "Exporra automates ECCN and HS code classification and performs sanction, denied party and KYC screening against OFAC, BIS, EU and UN lists with continuous regulatory monitoring.",
                "offers": {
                    "@type": "Offer",
                    "price": "0",
                    "priceCurrency": "USD",
                    "availability": "https://schema.org/PreOrder"
                }
            }

        // Structured data — FAQ
        script(type='application/ld+json').
            {
                "@context": "https://schema.org",
                "@type": "FAQPage",
                "mainEntity": [
                    {
                        "@type": "Question",
                        "name": "What is automated ECCN and HS code classification?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Automated ECCN and HS code classification uses AI to analyze product descriptions and technical specifications and assign accurate Export Control Classification Numbers (ECCN) and Harmonized System (HS) codes, ensuring compliance with export control laws."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "What is sanction and denied party screening?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Sanction and denied/restricted party screening cross-references customers and partners against global watchlists such as OFAC, BIS, EU consolidated sanctions, and UN sanctions lists to detect prohibited transactions before they occur."
                        }
                    },
                    {
                        "@type": "Question",
                        "name": "How does Exporra keep classifications up to date?",
                        "acceptedAnswer": {
                            "@type": "Answer",
                            "text": "Exporra continuously monitors regulatory changes and sanctions list updates and notifies you when changes affect your products, customers or partners, so your classifications and screening remain accurate."
                        }
                    }
                ]
            }

